generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  READER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommentModerationRuleMode {
  ALLOW
  BLOCK
}

enum CommentModerationRuleSeverity {
  REVIEW
  REJECT
}

enum JournalStatus {
  DRAFT
  PUBLISHED
}

enum ProviderAdapter {
  OPENAI_COMPATIBLE
  ANTHROPIC
}

enum PaperReadingStatus {
  TO_READ
  READING
  COMPLETED
  ARCHIVED
}

enum RagChunkVisibility {
  PUBLIC
  PRIVATE
}

enum RagSourceType {
  POST
  NOTE
  JOURNAL
  DIGEST
  DAILY_PAPER
  PAPER_LIBRARY_ITEM
  PAPER_ANNOTATION
}

model User {
  id                        String                   @id @default(cuid())
  name                      String
  email                     String                   @unique
  avatarUrl                 String?
  passwordHash              String
  role                      UserRole                 @default(READER)
  status                    UserStatus               @default(ACTIVE)
  twoFactorEnabled          Boolean                  @default(false)
  twoFactorSecret           String?
  twoFactorTempSecret       String?
  twoFactorEnabledAt        DateTime?
  emailVerifiedAt           DateTime?
  emailVerificationRequired Boolean                  @default(false)
  emailPostNotifications    Boolean                  @default(false)
  mutedUntil                DateTime?
  muteReason                String?                  @db.Text
  statusReason              String?                  @db.Text
  lastLoginAt               DateTime?
  lastLoginIpHash           String?
  lastLoginUserAgentHash    String?
  deletedAt                 DateTime?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  sessions                  Session[]
  twoFactorChallenges       TwoFactorChallenge[]
  posts                     Post[]
  postRevisionsAuthored     PostRevision[]           @relation("PostRevisionActor")
  notes                     Note[]
  noteRevisionsAuthored     NoteRevision[]           @relation("NoteRevisionActor")
  comments                  Comment[]
  auditLogsAuthored         AdminAuditLog[]          @relation("AdminAuditActor")
  auditLogsTargeted         AdminAuditLog[]          @relation("AdminAuditTarget")
  paperLibraryItems         PaperLibraryItem[]
  paperAnnotations          PaperAnnotation[]
  emailVerificationTokens   EmailVerificationToken[]
  passwordResetTokens       PasswordResetToken[]
  notifications             UserNotification[]
  commentModerationRulesCreated CommentModerationRule[] @relation("CommentModerationRuleCreator")

  @@index([role, status])
  @@index([status])
  @@index([mutedUntil])
  @@index([emailVerificationRequired, emailVerifiedAt])
}

model UserNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String   @db.Text
  href      String?
  metadata  Json?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TwoFactorChallenge {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  expiresAt     DateTime
  attempts      Int      @default(0)
  ipHash        String?
  userAgentHash String?
  createdAt     DateTime @default(now())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  action       String
  summary      String
  metadata     Json?
  createdAt    DateTime @default(now())
  actorId      String?
  targetUserId String?
  actor        User?    @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser   User?    @relation("AdminAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([targetUserId, createdAt(sort: Desc)])
}

model SiteProfile {
  id                 String   @id @default("main")
  fullName           String
  headline           String
  tagline            String
  shortBio           String   @db.Text
  longBio            String   @db.Text
  institution        String?
  department         String?
  location           String?
  email              String?
  websiteUrl         String?
  githubUrl          String?
  linkedinUrl        String?
  scholarUrl         String?
  cvUrl              String?
  heroImageUrl       String?
  backgroundImageUrl String?
  assistantAvatarUrl String?
  researchAreas      String[]
  educationMarkdown  String   @db.Text
  experienceMarkdown String   @db.Text
  awardsMarkdown     String   @db.Text
  speakingMarkdown   String   @db.Text
  updatedAt          DateTime @updatedAt
}

model ContentSeries {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  summary       String         @db.Text
  description   String         @db.Text
  coverImageUrl String?
  featured      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  posts         Post[]
  notes         Note[]
  weeklyDigests WeeklyDigest[]

  @@index([featured, updatedAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}

model Post {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String     @db.Text
  content         String     @db.Text
  category        String
  tags            String[]
  status          PostStatus @default(DRAFT)
  pinned          Boolean    @default(false)
  featured        Boolean    @default(false)
  coverImageUrl   String?
  readTimeMinutes Int        @default(5)
  seriesId        String?
  seriesOrder     Int?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  authorId        String
  author          User       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  comments        Comment[]
  revisions       PostRevision[]
  series          ContentSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([status, pinned, publishedAt(sort: Desc)])
  @@index([category])
  @@index([seriesId, seriesOrder])
}

model PostRevision {
  id              String     @id @default(cuid())
  version         Int
  title           String
  slug            String
  excerpt         String     @db.Text
  content         String     @db.Text
  category        String
  tags            String[]
  status          PostStatus
  pinned          Boolean
  featured        Boolean
  coverImageUrl   String?
  readTimeMinutes Int
  seriesId        String?
  seriesOrder     Int?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  postId          String
  actorId         String?
  post            Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  actor           User?      @relation("PostRevisionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([postId, version])
  @@index([postId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
}

model Note {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  summary     String     @db.Text
  content     String     @db.Text
  noteType    String?
  tags        String[]
  status      PostStatus @default(DRAFT)
  featured    Boolean    @default(false)
  seriesId    String?
  seriesOrder Int?
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  revisions   NoteRevision[]
  series      ContentSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt(sort: Desc)])
  @@index([noteType])
  @@index([seriesId, seriesOrder])
}

model NoteRevision {
  id          String     @id @default(cuid())
  version     Int
  title       String
  slug        String
  summary     String     @db.Text
  content     String     @db.Text
  noteType    String?
  tags        String[]
  status      PostStatus
  featured    Boolean
  seriesId    String?
  seriesOrder Int?
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  noteId      String
  actorId     String?
  note        Note       @relation(fields: [noteId], references: [id], onDelete: Cascade)
  actor       User?      @relation("NoteRevisionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([noteId, version])
  @@index([noteId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
}

model JournalEntry {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  summary     String        @db.Text
  content     String        @db.Text
  mood        String?
  status      JournalStatus @default(PUBLISHED)
  publishedAt DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, publishedAt(sort: Desc)])
}

model Comment {
  id                String        @id @default(cuid())
  content           String        @db.Text
  status            CommentStatus @default(PENDING)
  moderationNotes   String?       @db.Text
  moderationMatches String[]      @default([])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  postId            String
  authorId          String
  parentId          String?
  post              Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author            User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent            Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies           Comment[]     @relation("CommentReplies")

  @@index([postId, status, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([parentId])
}

model CommentModerationRule {
  id             String                        @id @default(cuid())
  term           String
  normalizedTerm String
  mode           CommentModerationRuleMode    @default(BLOCK)
  severity       CommentModerationRuleSeverity @default(REVIEW)
  enabled        Boolean                       @default(true)
  notes          String?                       @db.Text
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt
  createdById    String?
  createdBy      User?                         @relation("CommentModerationRuleCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([normalizedTerm, mode])
  @@index([enabled, mode, severity])
  @@index([createdById])
}

model AuthAttempt {
  id        String   @id @default(cuid())
  email     String
  ipHash    String?
  userAgent String?
  succeeded Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt(sort: Desc)])
  @@index([ipHash, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model LlmProvider {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  adapter      ProviderAdapter @default(OPENAI_COMPATIBLE)
  baseUrl      String
  model        String
  apiKeyEnv    String
  systemPrompt String?         @db.Text
  enabled      Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model PaperTopic {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?           @db.Text
  query       String            @db.Text
  maxResults  Int               @default(5)
  enabled     Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  entries     DailyPaperEntry[]
}

model DailyPaperEntry {
  id              String     @id @default(cuid())
  digestDate      DateTime
  arxivId         String
  title           String
  summary         String     @db.Text
  authors         String[]
  paperUrl        String
  pdfUrl          String?
  primaryCategory String?
  publishedAt     DateTime
  updatedAt       DateTime
  createdAt       DateTime   @default(now())
  topicId         String
  topic           PaperTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([digestDate, topicId, arxivId])
  @@index([digestDate(sort: Desc)])
  @@index([topicId, digestDate(sort: Desc)])
}

model PaperLibraryItem {
  id              String             @id @default(cuid())
  arxivId         String
  title           String
  summary         String             @db.Text
  authors         String[]
  paperUrl        String
  pdfUrl          String?
  primaryCategory String?
  topicName       String?
  digestDate      DateTime?
  publishedAt     DateTime?
  status          PaperReadingStatus @default(TO_READ)
  progressPercent Int                @default(0)
  startedAt       DateTime?
  lastReadAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  annotations     PaperAnnotation[]

  @@unique([userId, arxivId])
  @@index([userId, status, updatedAt(sort: Desc)])
  @@index([userId, lastReadAt(sort: Desc)])
  @@index([arxivId])
}

model PaperAnnotation {
  id            String           @id @default(cuid())
  content       String           @db.Text
  quote         String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  libraryItemId String
  userId        String
  libraryItem   PaperLibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([libraryItemId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteVisitor {
  id          String   @id @default(cuid())
  ipHash      String   @unique
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  visitCount  Int      @default(1)
  lastPath    String?
  countryCode String?
  regionKey   String?
  regionLabel String?
  timezone    String?
  language    String?
  userAgent   String?  @db.Text

  @@index([lastSeenAt(sort: Desc)])
  @@index([regionKey, lastSeenAt(sort: Desc)])
}

model PageView {
  id            String   @id @default(cuid())
  path          String
  visitorIpHash String?
  countryCode   String?
  regionKey     String?
  regionLabel   String?
  createdAt     DateTime @default(now())

  @@index([path, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([visitorIpHash, createdAt(sort: Desc)])
}

model SearchQueryLog {
  id              String   @id @default(cuid())
  query           String
  normalizedQuery String
  resultCount     Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([normalizedQuery, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model WeeklyDigest {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  summary        String   @db.Text
  content        String   @db.Text
  highlights     String[]
  featuredTopics String[]
  paperCount     Int      @default(0)
  journalCount   Int      @default(0)
  postCount      Int      @default(0)
  seriesId       String?
  seriesOrder    Int?
  periodStart    DateTime
  periodEnd      DateTime
  publishedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  series         ContentSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@unique([periodStart, periodEnd])
  @@index([publishedAt(sort: Desc)])
  @@index([seriesId, seriesOrder])
}

model RagKnowledgeChunk {
  id          String             @id @default(cuid())
  sourceKey   String
  sourceType  RagSourceType
  sourceId    String
  ownerUserId String?
  visibility  RagChunkVisibility @default(PUBLIC)
  title       String
  href        String
  kindLabel   String
  chunkIndex  Int
  snippet     String             @db.Text
  content     String             @db.Text
  embedding   Float[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([sourceKey, chunkIndex])
  @@index([visibility, ownerUserId])
  @@index([sourceType, sourceId])
  @@index([updatedAt(sort: Desc)])
}
